# =============================================================================
# Hermes Email — Environment Variables
# Copy to .env and fill in your values.
# =============================================================================

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# --- Email Provider: Maton ---
# Only needed if using the Maton gateway for Gmail
MATON_API_KEY=your-maton-api-key

# --- AI Providers (at least one required) ---
ANTHROPIC_API_KEY=sk-ant-...
MINIMAX_API_KEY=your-minimax-key
OPENAI_API_KEY=sk-...

# --- Notifications (optional) ---
# Webhook URL for push notifications on new emails
NOTIFICATION_WEBHOOK_URL=https://hooks.example.com/notify
